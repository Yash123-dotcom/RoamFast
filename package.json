{
  "name": "neonstay",
  "private": true,
  "description": "NeonStay Hotel Aggregator Monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "db:generate": "npm run generate -w packages/database",
    "db:push": "npm run push -w packages/database"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
